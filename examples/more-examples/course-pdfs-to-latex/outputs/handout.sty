%% handout.sty
%% ---------------------------------------------------------------------------
%% Recreated worksheet/problem-set style package, modeled on a provided
%% "template to follow" whose own custom style package was never shipped.
%%
%% The original template referenced a custom package (../Documents/handout)
%% that was never included, so this file reconstructs that package AND folds
%% in the visual preamble that the Template repeated inline. Each document now
%% only needs a short preamble:  \usepackage[<options>]{../handout}
%%
%% Package options:
%%   sols     -- reveal \begin{solution}...\end{solution} blocks
%%   grading  -- reveal \begin{grading}...\end{grading} blocks
%%   plan     -- reveal \begin{plan}... and \begin{note}... blocks
%% With no options you get the clean student handout (problems only, with
%% working space).
%%
%% Accessibility (institution digital accessibility policy -> WCAG 2.1 AA):
%%   * PDF metadata + document language are set for screen readers.
%%   * axessibility (if available) embeds the LaTeX source of every equation
%%     as actual/alt text so equations are not lost to assistive tech.
%%   * Status of each version (Student / Solutions / etc.) is conveyed in
%%     TEXT, never by color alone.
%%   * Link and header colors are chosen to meet WCAG AA contrast on white.
%%   NOTE: fully *tagged* PDF output requires lualatex + tagpdf and is out of
%%   reach with the xetex-based Tectonic engine; see ACCESSIBILITY.md.
%% ---------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{handout}[2026/06/10 Accessible DE worksheet/PSet style]

% ---- option flags ----------------------------------------------------------
\newif\ifhandout@sols     \handout@solsfalse
\newif\ifhandout@grading  \handout@gradingfalse
\newif\ifhandout@plan     \handout@planfalse
\DeclareOption{sols}{\handout@solstrue}
\DeclareOption{grading}{\handout@gradingtrue}
\DeclareOption{plan}{\handout@plantrue}
\ProcessOptions\relax

% ---- core packages (formerly inline in the Template preamble) ---------------
\RequirePackage{amsmath, amssymb}
\RequirePackage[margin=1in]{geometry}
\RequirePackage{enumitem}
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric, backgrounds, calc}
\RequirePackage{calc}
\RequirePackage{multicol}
\RequirePackage{comment}
\RequirePackage{xcolor}

% Accessibility-minded color choices.
% color1 on white = 5.4:1 contrast (passes WCAG AA for normal & large text);
% color2 is a pale fill always paired with black text (very high contrast).
\definecolor{color1}{RGB}{0, 99, 178}   % Electric Blue (headers, links)
\definecolor{color2}{RGB}{193, 228, 242} % Sky Blue (callout fills)

\setlength{\parskip}{1ex}
\setlength{\parindent}{0pt}

\newlength{\topedge}
\newlength{\bottomedge}

% ---- section / subsection styling (blue banners) ---------------------------
\RequirePackage{titlesec, titletoc}
\titleformat{\section}[display]{}{}{0pt}{%
    \bfseries\Large\color{white}%
    \setlength{\topedge}{0.9\baselineskip}%
    \setlength{\bottomedge}{-0.4\baselineskip}%
    \begin{tikzpicture}[overlay, x=1in, y=1in]
        \fill[color1] (-1, \bottomedge) -- (6.5, \bottomedge) -- (6.2, \topedge) -- (-1, \topedge) -- cycle;
    \end{tikzpicture}%
}[]
\titlespacing*{\section}{0pt}{-3ex}{1ex}

\titleformat{\subsection}[display]{}{}{0pt}{%
    \bfseries\large\color{white}%
    \setlength{\topedge}{0.9\baselineskip}%
    \setlength{\bottomedge}{-0.4\baselineskip}%
    \begin{tikzpicture}[overlay, x=1in, y=1in]
        \fill[color1] (-1, \bottomedge) -- (2.75, \bottomedge) -- (2.5, \topedge) -- (-1, \topedge) -- cycle;
    \end{tikzpicture}%
}[]
\titlespacing*{\subsection}{0pt}{-2ex}{0pt}

% ---- pgfplots defaults ------------------------------------------------------
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.16}
\pgfplotsset{
    cycle list=black,
    every axis plot/.style={no marks, thick},
    tick label style = {font=\footnotesize, inner sep=0pt},
    scaled ticks=false,
    samples=101,
    width=3in,
}

% ---- hyperlinks + PDF metadata (accessibility) ------------------------------
\RequirePackage[colorlinks, linkcolor=color1, urlcolor=color1, citecolor=color1]{hyperref}
\hypersetup{
    pdflang={en-US},
    pdfdisplaydoctitle=true,
}

% Equation-level alt text (axessibility) requires the LaTeX PDF management
% layer / lualatex and fails under the xetex-based Tectonic engine, so it is
% intentionally NOT loaded here. To embed LaTeX-source alt text on equations,
% compile with lualatex and uncomment the next line. See ACCESSIBILITY.md.
% \RequirePackage{axessibility}

% ---- list styling -----------------------------------------------------------
\RequirePackage{fdsymbol}
\setlist{itemsep=1ex, parsep=1ex, topsep=1ex}
\setlist[itemize]{label={\color{color1} $\smallblackdiamond$}}

% ---- fancy trapezoid problem numbers ---------------------------------------
\DeclareRobustCommand{\numbox}[1]{\tikz[overlay, baseline=-10pt, trapezium stretches=true] \node[trapezium, trapezium left angle=45, trapezium right angle=90, shape border rotate=90, anchor=north, text depth=1cm, inner ysep=8pt, fill=color1, text=white, font=\Large]{#1}; \,}
\DeclareRobustCommand{\shortnumbox}[1]{\tikz[overlay, baseline=-10pt, trapezium stretches=true] \node[trapezium, trapezium left angle=45, trapezium right angle=90, shape border rotate=90, anchor=north, inner ysep=8pt, fill=color1, text=white, font=\Large]{#1}; \,}

% ===========================================================================
%  Title block + callout helper macros
% ===========================================================================
% \handouttitle{<subject>}{<kind, e.g. Class 1 / Problem Set 1>}{<date>}
\newcommand{\handouttitle}[3]{%
    \begin{center}
        \begin{tikzpicture}
            \node (title) [trapezium, trapezium left angle=60, trapezium right angle=120, align=center, inner sep=10pt, fill=color1, text=white] at (0, 0) {\bfseries\LARGE #1};
            \node[trapezium, trapezium left angle=120, trapezium right angle=60, align=center, inner sep=6pt, fill=color2, text=black]
                at ($(title.top left corner) + (0,0.2)$) {\large #2};
            \node[trapezium, trapezium left angle=120, trapezium right angle=60, align=center, inner sep=6pt, fill=color2, text=black]
                at ($(title.bottom right corner) + (0,-0.2)$) {\large #3};
        \end{tikzpicture}
    \end{center}%
}

% \calloutbox{<heading>}{<body>} -- the "Today's Goals" / "PSet Tips" box
\newcommand{\calloutbox}[2]{%
    \begin{center}
        \hspace*{-1in}
        \begin{tikzpicture}
            \node (cb) [trapezium, trapezium left angle=100, trapezium right angle=80, align=center, inner sep=8pt, fill=color2, text=black] at (0, 0)
                {\begin{minipage}{\textwidth}#2\end{minipage}};
            \node[trapezium, trapezium left angle=60, trapezium right angle=120, align=center, anchor=bottom left corner, inner sep=6pt, fill=color1, text=white] at ($(cb.top left corner) + (0.8, -0.15)$) {\bfseries #1};
        \end{tikzpicture}
        \hspace*{-1in}
    \end{center}%
}

% ===========================================================================
%  Conditional content environments
% ===========================================================================
% problem: always shown. Optional arg is trailing working-space (e.g. \vfill),
% inserted ONLY in the student handout (suppressed when solutions are shown).
\newenvironment{problem}[1][]%
    {\def\handout@probtrail{#1}\ignorespaces}%
    {\ifhandout@sols\else\handout@probtrail\fi\par}

% solution: shown only with [sols]. Labeled in text (not color alone).
\ifhandout@sols
    \newenvironment{solution}{\par\nobreak{\color{color1}\bfseries Solution.}\enspace\ignorespaces}{\par}
\else
    \excludecomment{solution}
\fi

% grading: shown only with [grading].
\ifhandout@grading
    \newenvironment{grading}{\par\nobreak{\color{color1}\bfseries Grading.}\enspace\itshape\ignorespaces}{\par}
\else
    \excludecomment{grading}
\fi

% note + plan: teacher-facing, shown only with [plan].
\ifhandout@plan
    \newenvironment{note}{\par\nobreak{\color{color1}\bfseries Note.}\enspace\itshape\ignorespaces}{\par}
    \newenvironment{plan}{}{}
\else
    \excludecomment{note}
    \excludecomment{plan}
\fi

% problemonly: content for the student handout; hidden once solutions show.
\ifhandout@sols
    \excludecomment{problemonly}
\else
    \newenvironment{problemonly}{}{}
\fi

\endinput
